@prefix ex: <http://chloedroid.github.io/lab_2_publishing_RDF_data/vocab.ttl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .

#       .__                                      
#  ____ |  | _____    ______ ______ ____   ______
#_/ ___\|  | \__  \  /  ___//  ___// __ \ /  ___/
#\  \___|  |__/ __ \_\___ \ \___ \\  ___/ \___ \ 
# \___  >____(____  /____  >____  >\___  >____  >
#     \/          \/     \/     \/     \/     \/ 

ex:Person a rdfs:Class ;
	rdfs:label "Person"@en, "Persoon"@nl ;
	rdfs:subClassOf foaf:Person ;
	rdfs:comment "An individual human being; a man, woman, or child."@en .

ex:Municipality a rdfs:Class ;
	rdfs:label "Municipality"@en, "Gemeente"@nl ;
	rdfs:comment "A municipality is a single administrative division having corporate status and powers of self-government or jurisdiction as granted by national and regional laws to which it is subordinate."@en .
	
ex:Organisation a rdfs:Class ;
	rdfs:label "Organisation"@en, "Organisatie"@nl ;
	rdfs:comment "An organisation is an entity comprising one or more people and having a particular purpose."@en .
	
ex:MaritalStatus a rdfs:Class;
	rdfs:label "Marital Status"@en, "Burgerlijke staat"@nl ;
	rdfs:comment "Marital status is a civil status that indicates whether a person is married or not."@en .
	
ex:MusicArtist a rdfs:Class ; 
	rdfs:label "Music artist"@en, "Muzikant"@nl ;
	rdfs:comment "A music artist is someone or a group of people who composes, conducts or performs music."@en .

ex:Course a rdfs:Class ;
	rdfs:label "Course"@en, "Vak"@nl ;
	rdfs:comment "A course in school is a structured, distinct unit of study focused on a specific subject."@en .
	
ex:DigitalRepresentation a rdfs:Class ;
	rdfs:subClassOf foaf:Image ;
	rdfs:label "Digital representation"@en, "Digitale representatie"@nl ;
	rdfs:comment "A digital representation of an heritage object captured using a scanner or a camera."@en .

ex:Object a rdfs:Class ;
	rdfs:label "object"@en ;
	rdfs:subClassOf crm:E22_Man-Made_Object ;
	rdfs:comment "It comprises all persistent physical objects that are purposely created by human activity."@en .

ex:Thing a rdfs:Class ;
	rdfs:label "Thing"@en, "Ding"@nl ;
	rdfs:comment "An object or entity not precisely designated or capable of being designated."@en .
	
ex:RightsStatus a rdfs:Class ;
	rdfs:label "Rights status"@en, "Rechtenstatus"@nl;
	rdfs:comment "The status of a digital representation of an object that states if the representation is a copyrighted work or not."@en .
	
ex:Date a rdfs:Class ;
	rdfs:label "Date"@en, "Datum"@nl ;
	rdfs:comment "A particular day, month, or year."@en .
	
#                                          __  .__               
#_____________  ____ ______   ____________/  |_|__| ____   ______
#\____ \_  __ \/  _ \\____ \_/ __ \_  __ \   __\  |/ __ \ /  ___/
#|  |_> >  | \(  <_> )  |_> >  ___/|  | \/|  | |  \  ___/ \___ \ 
#|   __/|__|   \____/|   __/ \___  >__|   |__| |__|\___  >____  >
#|__|                |__|        \/                    \/     \/ 
	
ex:personalName a rdf:Property ;
	rdfs:label "personal name"@en, "persoonsnaam"@nl ;
	rdfs:subClassOf foaf:name ;
	rdfs:comment "A personal name is the set of names by which an individual person is known."@en ;
	rdfs:domain ex:Person ;
	rdfs:range xsd:string .
	
ex:age a rdf:Property ;
	rdfs:label "age"@en, "leeftijd"@nl ;
	rdfs:comment "An age indicates how many years old a person is."@en ;
	rdfs:domain ex:Person ;
	rdfs:range xsd:integer . 
	
ex:worksAt a rdf:Property ;
	rdfs:label "works at"@en, "werkt bij"@nl ;
	rdfs:comment "Indicates the organisation where an individual is employed."@en ;
	rdfs:domain ex:Person ;
	rdfs:range ex:Organisation .
	
ex:livesIn a rdf:Property ;
	rdfs:label "lives in"@en, "woont in"@nl ;
	rdfs:comment "Indicates the municipality where an indiviual resides."@en ;
	rdfs:domain ex:Person ;
	rdfs:range ex:Municipality .
	
ex:maritalStatus a rdf:Property ;
    rdfs:label "marital status"@en, "burgerlijke staat"@nl ;
    rdfs:comment "Specifies the marital status of a person."@en ;
    rdfs:domain ex:Person ;
    rdfs:range ex:MaritalStatus .
	
ex:isListeningTo a rdf:Property ;
    rdfs:label "is listening to"@en, "luistert naar"@nl ;
    rdfs:comment "Indicates a music artist currently being listened to by a person."@en ;
    rdfs:domain ex:Person ;
    rdfs:range ex:MusicArtist .
	
ex:knows a rdf:Property ;
    rdfs:label "knows"@en, "kent"@nl ;
	rdfs:subPropertyOf foaf:knows ;
    rdfs:comment "Indicates a relationship of any nature between two persons." ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:isFollowing a rdf:Property ;
	rdfs:label "is following"@en, "volgt"@nl ;
	rdfs:comment "Is taking part in."@en ;
	rdfs:domain ex:Person ;
	rdfs:range ex:Course . 

ex:seeAlso a rdf:Property ;
	rdfs:label "see also"@en, "zie ook"@nl ;
	rdfs:comment "Relates a entity to another entity."@en ;
	rdfs:domain rdfs:Resource ;
	rdfs:range rdfs:Resource . 

ex:title a rdf:Property ;
	rdfs:label "title"@en, "titel"@nl ;
	rdfs:subPropertyOf foaf:name ;
	rdfs:comment "The title of an object"@en ;
	rdfs:domain ex:Object ;
	rdfs:range rdfs:Literal . 

ex:creator a rdf:Property ;
	rdfs:label "creator"@en, "vervaardiger"@nl ;
	rdfs:subPropertyOf foaf:maker ;
	rdfs:comment "A person or thing that brings something into existence."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Person . 

ex:description a rdf:Property ;
	rdfs:label "description"@en, "beschrijving"@nl ;
	rdfs:comment "A written account of a person, object, or event." ;
	rdfs:domain ex:Object ;
	rdfs:range xsd:string . 

ex:depicts a rdf:Property ;
	rdfs:label "depicts"@en, "beeldt af"@nl ;
	rdfs:subPropertyOf foaf:depicts ;
	rdfs:comment "A thing depicted in this representation."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Thing .
	
ex:relatedTo a rdf:Property ;
	rdfs:label "related to"@en, "gerelateerd tot"@nl ;
	rdfs:comment "A object or entity that is connected with something."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Thing . 
	
ex:isInCollectionOf a rdf:Property ;
	rdfs:label "is in collection of"@en, "is in de collectie van"@nl ;
	rdfs:comment "Is managed in the following heritage collection."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Organisation . 
	
ex:hasAsRightsStatus a rdf:Property ;
	rdfs:label "has rights status"@en, "heeft rechtenstatus"@nl ;
	rdfs:comment "Has the following status concerning copyright."@en ;
	rdfs:domain ex:DigitalRepresentation ;
	rdfs:range ex:RightsStatus .
	
ex:dateOfCreation a rdf:Property ;
	rdfs:label "date of creation"@en, "datum van creatie"@nl ;
	rdfs:comment "The date, year and/or month the object was created or produced."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Date .
	
ex:placeOfCreation a rdf:Property ;
	rdfs:label "place of creation"@en, "plaats van creatie"@nl ;
	rdfs:comment "Where the creation or production took place."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:Municipality .

ex:hasAsDigitalRepresentation a rdf:Property ;
	rdfs:subPropertyOf foaf:depiction ;
	rdfs:label "has as digital representation of"@en, "heeft als digitale representatie"@nl ;
	rdfs:comment "A digital representation of an object captured using a scanner or a camera."@en ;
	rdfs:domain ex:Object ;
	rdfs:range ex:DigitalRepresentation .
	

